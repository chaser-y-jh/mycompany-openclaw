// Default signing values for shared/repo builds.
// Auto-selected local team overrides live in .local-signing.xcconfig (git-ignored).
// Manual local overrides can go in LocalSigning.xcconfig (git-ignored).

#include "Config/Version.xcconfig"

MERCLAW_CODE_SIGN_STYLE = Manual
MERCLAW_DEVELOPMENT_TEAM = Y5PE65HELJ

MERCLAW_APP_BUNDLE_ID = ai.merclaw.client
MERCLAW_SHARE_BUNDLE_ID = ai.merclaw.client.share
MERCLAW_WATCH_APP_BUNDLE_ID = ai.merclaw.client.watchkitapp
MERCLAW_WATCH_EXTENSION_BUNDLE_ID = ai.merclaw.client.watchkitapp.extension
MERCLAW_ACTIVITY_WIDGET_BUNDLE_ID = ai.merclaw.client.activitywidget

MERCLAW_APP_PROFILE = ai.merclaw.client Development
MERCLAW_SHARE_PROFILE = ai.merclaw.client.share Development

// Keep local includes after defaults: xcconfig is evaluated top-to-bottom,
// so later assignments in local files override the defaults above.
#include? ".local-signing.xcconfig"
#include? "LocalSigning.xcconfig"
