// Copy to LocalSigning.xcconfig for personal local signing overrides.
// This file is only an example and should stay committed.

MERCLAW_CODE_SIGN_STYLE = Automatic
MERCLAW_DEVELOPMENT_TEAM = YOUR_TEAM_ID

MERCLAW_APP_BUNDLE_ID = ai.merclaw.client
MERCLAW_SHARE_BUNDLE_ID = ai.merclaw.client.share
MERCLAW_ACTIVITY_WIDGET_BUNDLE_ID = ai.merclaw.client.activitywidget
MERCLAW_WATCH_APP_BUNDLE_ID = ai.merclaw.client.watchkitapp
MERCLAW_WATCH_EXTENSION_BUNDLE_ID = ai.merclaw.client.watchkitapp.extension

// Leave empty with automatic signing.
MERCLAW_APP_PROFILE =
MERCLAW_SHARE_PROFILE =
MERCLAW_WATCH_APP_PROFILE =
MERCLAW_WATCH_EXTENSION_PROFILE =
