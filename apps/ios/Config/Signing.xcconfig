// Shared iOS signing defaults for local development + CI.
#include "Version.xcconfig"

MERCLAW_IOS_DEFAULT_TEAM = Y5PE65HELJ
MERCLAW_IOS_SELECTED_TEAM = $(MERCLAW_IOS_DEFAULT_TEAM)
MERCLAW_DEVELOPMENT_TEAM = $(MERCLAW_IOS_SELECTED_TEAM)
MERCLAW_CODE_SIGN_STYLE = Automatic
MERCLAW_APP_BUNDLE_ID = ai.merclaw.client
MERCLAW_WATCH_APP_BUNDLE_ID = ai.merclaw.client.watchkitapp
MERCLAW_WATCH_EXTENSION_BUNDLE_ID = ai.merclaw.client.watchkitapp.extension
MERCLAW_ACTIVITY_WIDGET_BUNDLE_ID = ai.merclaw.client.activitywidget
MERCLAW_WATCH_APP_PROFILE =
MERCLAW_WATCH_EXTENSION_PROFILE =

// Local contributors can override this by running scripts/ios-configure-signing.sh.
// Keep include after defaults: xcconfig is evaluated top-to-bottom.
#include? "../.local-signing.xcconfig"
#include? "../LocalSigning.xcconfig"

CODE_SIGN_STYLE = $(MERCLAW_CODE_SIGN_STYLE)
CODE_SIGN_IDENTITY = Apple Development
DEVELOPMENT_TEAM = $(MERCLAW_DEVELOPMENT_TEAM)

// Let Xcode manage provisioning for the selected local team unless a local override pins one.
PROVISIONING_PROFILE_SPECIFIER =
