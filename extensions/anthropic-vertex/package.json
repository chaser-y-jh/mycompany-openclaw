{
  "name": "@merclaw/anthropic-vertex-provider",
  "version": "2026.5.31",
  "description": "MerClaw Anthropic Vertex provider plugin for Claude models on Google Vertex AI.",
  "repository": {
    "type": "git",
    "url": "https://github.com/merclaw/merclaw"
  },
  "type": "module",
  "dependencies": {
    "@anthropic-ai/vertex-sdk": "0.16.1"
  },
  "devDependencies": {
    "@merclaw/plugin-sdk": "workspace:*"
  },
  "merclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@merclaw/anthropic-vertex-provider",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.12-beta.1"
    },
    "compat": {
      "pluginApi": ">=2026.5.31"
    },
    "build": {
      "merclawVersion": "2026.5.31",
      "bundledDist": false
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
