{
  "name": "@merclaw/tokenjuice",
  "version": "2026.5.31",
  "description": "MerClaw tokenjuice exec output compaction plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/merclaw/merclaw"
  },
  "type": "module",
  "dependencies": {
    "tokenjuice": "0.8.0"
  },
  "peerDependencies": {
    "merclaw": ">=2026.5.31"
  },
  "peerDependenciesMeta": {
    "merclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@merclaw/plugin-sdk": "workspace:*",
    "merclaw": "2026.5.28"
  },
  "merclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "clawhubSpec": "clawhub:@merclaw/tokenjuice",
      "npmSpec": "@merclaw/tokenjuice",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.28"
    },
    "compat": {
      "pluginApi": ">=2026.5.31"
    },
    "build": {
      "merclawVersion": "2026.5.31",
      "bundledDist": false
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
