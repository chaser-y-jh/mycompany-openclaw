{
  "name": "@merclaw/synology-chat",
  "version": "2026.5.31",
  "description": "Synology Chat channel plugin for MerClaw channels and direct messages.",
  "repository": {
    "type": "git",
    "url": "https://github.com/merclaw/merclaw"
  },
  "type": "module",
  "devDependencies": {
    "@merclaw/plugin-sdk": "workspace:*"
  },
  "merclaw": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "channel": {
      "id": "synology-chat",
      "label": "Synology Chat",
      "selectionLabel": "Synology Chat (Webhook)",
      "docsPath": "/channels/synology-chat",
      "docsLabel": "synology-chat",
      "blurb": "Connect your Synology NAS Chat to MerClaw with full agent capabilities.",
      "order": 90
    },
    "install": {
      "npmSpec": "@merclaw/synology-chat",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.5.31"
    },
    "build": {
      "merclawVersion": "2026.5.31"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  },
  "dependencies": {
    "zod": "4.4.3"
  }
}
