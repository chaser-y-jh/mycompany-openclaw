{
  "name": "@merclaw/voice-call",
  "version": "2026.5.31",
  "description": "MerClaw voice-call plugin for Twilio, Telnyx, and Plivo phone calls.",
  "repository": {
    "type": "git",
    "url": "https://github.com/merclaw/merclaw"
  },
  "type": "module",
  "dependencies": {
    "commander": "14.0.3",
    "typebox": "1.1.39",
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@merclaw/plugin-sdk": "workspace:*",
    "merclaw": "2026.5.28"
  },
  "peerDependencies": {
    "merclaw": ">=2026.5.31"
  },
  "peerDependenciesMeta": {
    "merclaw": {
      "optional": true
    }
  },
  "merclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@merclaw/voice-call",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.5.31"
    },
    "build": {
      "merclawVersion": "2026.5.31"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
