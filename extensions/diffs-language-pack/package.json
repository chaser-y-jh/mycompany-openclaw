{
  "name": "@merclaw/diffs-language-pack",
  "version": "2026.5.31",
  "description": "MerClaw diffs viewer syntax highlighting language pack",
  "repository": {
    "type": "git",
    "url": "https://github.com/merclaw/merclaw"
  },
  "type": "module",
  "devDependencies": {
    "@merclaw/plugin-sdk": "workspace:*"
  },
  "merclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@merclaw/diffs-language-pack",
      "clawhubSpec": "clawhub:@merclaw/diffs-language-pack",
      "localPath": "extensions/diffs-language-pack",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.27"
    },
    "compat": {
      "pluginApi": ">=2026.5.31"
    },
    "assetScripts": {
      "build": "node ../../scripts/build-diffs-viewer-runtime.mjs full"
    },
    "build": {
      "merclawVersion": "2026.5.31",
      "staticAssets": [
        {
          "source": "./assets/viewer-runtime.js",
          "output": "assets/viewer-runtime.js"
        }
      ]
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
