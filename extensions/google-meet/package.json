{
  "name": "@merclaw/google-meet",
  "version": "2026.5.31",
  "description": "MerClaw Google Meet participant plugin for joining calls through Chrome or Twilio transports.",
  "repository": {
    "type": "git",
    "url": "https://github.com/merclaw/merclaw"
  },
  "type": "module",
  "dependencies": {
    "commander": "14.0.3",
    "typebox": "1.1.39"
  },
  "devDependencies": {
    "@merclaw/plugin-sdk": "workspace:*",
    "merclaw": "2026.5.28"
  },
  "peerDependencies": {
    "merclaw": ">=2026.5.31"
  },
  "peerDependenciesMeta": {
    "merclaw": {
      "optional": true
    }
  },
  "merclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@merclaw/google-meet",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.20"
    },
    "compat": {
      "pluginApi": ">=2026.5.31"
    },
    "build": {
      "merclawVersion": "2026.5.31"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
