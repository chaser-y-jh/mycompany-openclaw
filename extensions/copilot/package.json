{
  "name": "@merclaw/copilot",
  "version": "2026.5.31",
  "description": "MerClaw GitHub Copilot agent runtime plugin (registers a `github-copilot` AgentHarness backed by @github/copilot-sdk over JSON-RPC to the GitHub Copilot CLI)",
  "repository": {
    "type": "git",
    "url": "https://github.com/merclaw/merclaw"
  },
  "type": "module",
  "dependencies": {
    "@github/copilot-sdk": "1.0.0-beta.9"
  },
  "devDependencies": {
    "@github/copilot": "1.0.55",
    "@merclaw/plugin-sdk": "workspace:*"
  },
  "merclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "clawhubSpec": "clawhub:@merclaw/copilot",
      "npmSpec": "@merclaw/copilot",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.28"
    },
    "compat": {
      "pluginApi": ">=2026.5.31"
    },
    "build": {
      "merclawVersion": "2026.5.31",
      "bundledDist": false
    },
    "release": {
      "bundleRuntimeDependencies": false,
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
