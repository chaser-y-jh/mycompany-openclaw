{
  "entries": [
    {
      "name": "@merclaw/acpx",
      "description": "MerClaw ACP runtime backend",
      "source": "official",
      "kind": "plugin",
      "merclaw": {
        "plugin": {
          "id": "acpx",
          "label": "ACPX Runtime"
        },
        "install": {
          "npmSpec": "@merclaw/acpx",
          "defaultChoice": "npm",
          "minHostVersion": ">=2026.4.25"
        }
      }
    },
    {
      "name": "@merclaw/brave-plugin",
      "description": "MerClaw Brave plugin",
      "source": "official",
      "kind": "plugin",
      "merclaw": {
        "plugin": {
          "id": "brave",
          "label": "Brave"
        },
        "webSearchProviders": [
          {
            "id": "brave",
            "label": "Brave Search",
            "hint": "Brave Search web results.",
            "onboardingScopes": ["text-inference"],
            "credentialLabel": "Brave Search API key",
            "envVars": ["BRAVE_API_KEY"],
            "placeholder": "BSA...",
            "signupUrl": "https://api-dashboard.search.brave.com/app/keys",
            "docsUrl": "https://docs.merclaw.ai/tools/brave-search",
            "credentialPath": "plugins.entries.brave.config.webSearch.apiKey",
            "autoDetectOrder": 10
          }
        ],
        "install": {
          "npmSpec": "@merclaw/brave-plugin",
          "defaultChoice": "npm",
          "minHostVersion": ">=2026.4.10",
          "allowInvalidConfigRecovery": true
        }
      }
    },
